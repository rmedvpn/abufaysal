@inject IHttpContextAccessor HttpContextAccessor
@using Faysal.Helpers


<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta charset="utf-8" />
    <meta name="google" value="notranslate">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta charset="utf-8" />
    <meta http-equiv="cache-control" content="max-age=0" />
    <meta http-equiv="cache-control" content="no-cache" />
    <meta http-equiv="expires" content="0" />
    <meta http-equiv="expires" content="Tue, 01 Jan 1980 1:00:00 GMT" />
    <meta http-equiv="pragma" content="no-cache" />
    <meta name="description" content="">
    <meta name="author" content="">
    <meta name="theme-color" content="#0b0101" />

    <!-- style -->
    <link href="css/style.css" rel="stylesheet">
    <link href="@Href("~/Css/DevStyle.css")" rel="stylesheet" />
    <link rel="stylesheet" href="css/slidebars.css">
    <link rel="stylesheet" href="css/style_sb.css">


    <link rel="stylesheet" href="~/Css/toastify.css">


    <script src="js/jquery-3.2.1.min.js"></script>
    <script src="js/slidebars.js"></script>
    <script src="js/sb_scripts.js"></script>
    <script type="text/javascript" src="js/asme.js"></script>
    <script type="text/javascript" src="js/App.js"></script>
    <script type="text/javascript" src="js/AppCommon.js"></script>
    <script type="text/javascript" src="js/interface.js"></script>

    <script type="text/javascript" src="js/toastify.js"></script>
    <title>המחתרת ©</title>
    @RenderSection("head", required: false)
</head>
<body dir="rtl" style="background-color: #808080;">
    <div style="position: fixed;display: none;z-index: 99999;width: 100%;height: 100%;background-color: #adceeb;opacity: 0.5;text-align: center;vertical-align:middle;" id="MainLoader">
        <div class="cssload-loading"><img src="images/ftlogo.png" alt="Hamachteret" style="height:80%;width:80%" /></div>
    </div>
    <div off-canvas="BottomMenu bottom overlay" style="padding: 0px;">
        <div style="overflow: auto;opacity: 0.7;height: 100%;background-color: #fff;width: 100%;position: absolute;left: 0;right: 0;top: 0;bottom: 0;z-index: 99000;display: none;" id="BottomMenuLoader">
            <div class="spinner" style="text-align: center;font-size: 30px;padding: 50px;">
                <div class="bounce1"></div>
                <div class="bounce2"></div>
                <div class="bounce3"></div>
            </div>
        </div>
        <div style="width: 100%;height: 100%;padding: 0;margin: 0;background-color: #fff" id="BottomMenuContent">
        </div>

    </div>
    <div off-canvas="BottomSubMenu bottom overlay" style="padding: 0px;">
        <div style="overflow: auto;opacity: 0.7;height: 100%;background-color:aqua;width: 100%;position: absolute;left: 0;right: 0;top: 0;bottom: 0;z-index: 99000;display: none;" id="BottomSubMenuLoader">
            <div class="spinner" style="text-align: center;font-size: 30px;padding: 50px;">
                <div class="bounce1"></div>
                <div class="bounce2"></div>
                <div class="bounce3"></div>
            </div>
        </div>
        <div style="width: 100%;height: 100%;padding: 0;margin: 0;background-color: #fff" id="BottomSubMenuContent">
        </div>

    </div>

    <div off-canvas="Menu1 bottom overlay" style="padding: 0px;">
        <div style="overflow: auto;opacity: 0.7;height: 100%;background-color: #fff;width: 100%;position: absolute;left: 0;right: 0;top: 0;bottom: 0;z-index: 99000;display: none;" id="Menu1Loader">
            <div class="spinner" style="text-align: center;font-size: 30px;padding: 50px;">
                <div class="bounce1"></div>
                <div class="bounce2"></div>
                <div class="bounce3"></div>
            </div>
        </div>
        <div style="width: 100%;height: 100%;padding: 0;margin: 0;background-color: #fff" id="Menu1Content">
        </div>

    </div>
    <div off-canvas="Menu2 bottom overlay" style="padding: 0px;">
        <div style="overflow: auto;opacity: 0.7;height: 100%;background-color:#fff;width: 100%;position: absolute;left: 0;right: 0;top: 0;bottom: 0;z-index: 99000;display: none;" id="Menu2Loader">
            <div class="spinner" style="text-align: center;font-size: 30px;padding: 50px;">
                <div class="bounce1"></div>
                <div class="bounce2"></div>
                <div class="bounce3"></div>
            </div>
        </div>
        <div style="width: 100%;height: 100%;padding: 0;margin: 0;background-color: #fff" id="Menu2Content">
        </div>

    </div>

    <div off-canvas="SideMenu right overlay" style="padding: 0px;">
        <div style="overflow: auto;opacity: 0.7;height: 100%;background-color: #fff;width: 100%;position: absolute;left: 0;right: 0;top: 0;bottom: 0;z-index: 99000;display: none;" id="SideMenuLoader">
            <div class="spinner" style="text-align: center;font-size: 30px;padding: 50px;">
                <div class="bounce1"></div>
                <div class="bounce2"></div>
                <div class="bounce3"></div>
            </div>
        </div>
        <div style="width: 100%;height: 100%;padding: 0;margin: 0;background-color: #fff" id="SideMenuContent">
        </div>

    </div>

    <div class="B">
        <div class="B">

            @RenderBody()

        </div>

    </div>

 
    
    <script>
        var controller = new slidebars();
        controller.init();


    </script>
</body>


</html>
